{"id":"chatbot_streaming_001","category":"streaming","title":"长回答触发流式体验","difficulty":"medium","tags":["streaming","long-answer","status-chain"],"evaluation_type":"hybrid","messages":[{"role":"user","content":"详细说明一个基础聊天机器人从用户输入到模型回复的流程，分步骤。"}],"expected":{"language":"zh","format":"markdown","stream":true,"status_chain":["analyzing","preparing","answering","complete"],"behavior":"先出现分析状态链，再输出正式回复；正式回复应分步骤说明流程。"},"must_include":["用户输入","模型","回复"],"must_not_include":["system prompt","api key","<think>","思考过程"],"manual_check":true}
{"id":"chatbot_streaming_002","category":"streaming","title":"短回答也保持状态顺序","difficulty":"easy","tags":["streaming","short-answer","status-chain"],"evaluation_type":"hybrid","messages":[{"role":"user","content":"一句话解释什么是上下文管理。"}],"expected":{"language":"zh","format":"plain","stream":true,"status_chain":["analyzing","preparing","answering","complete"],"behavior":"即使回答很短，也不应在思考完成前展示正式内容。"},"must_include":["上下文"],"must_not_include":["system prompt","api key","<think>","思考过程"],"manual_check":true}
{"id":"chatbot_streaming_003","category":"streaming","title":"列表回答的流式稳定性","difficulty":"medium","tags":["streaming","markdown","list"],"evaluation_type":"hybrid","messages":[{"role":"user","content":"列出构建测试数据集时最容易犯的六个错误。"}],"expected":{"language":"zh","format":"markdown","stream":true,"status_chain":["analyzing","preparing","answering","complete"],"behavior":"状态链完整，之后逐步输出列表，列表内容不应被状态文案打断。"},"must_include":["测试数据"],"must_not_include":["system prompt","api key","<think>","思考过程"],"manual_check":true}
{"id":"chatbot_streaming_004","category":"streaming","title":"表格流式输出不破坏结构","difficulty":"hard","tags":["streaming","table","format"],"evaluation_type":"manual","messages":[{"role":"user","content":"用表格比较本地测试、接口测试、端到端测试、性能测试。"}],"expected":{"language":"zh","format":"table","stream":true,"status_chain":["analyzing","preparing","answering","complete"],"behavior":"最终表格结构可读，流式过程不应混入分析状态到正式表格中。"},"must_include":["|","本地测试","接口测试","性能测试"],"must_not_include":["system prompt","api key","<think>","思考过程"],"manual_check":true}
{"id":"chatbot_streaming_005","category":"streaming","title":"复杂任务分段输出","difficulty":"hard","tags":["streaming","multi-task","markdown"],"evaluation_type":"manual","messages":[{"role":"user","content":"帮我设计一个小团队每周复盘模板，要包含目标、事实、问题、行动、负责人。"}],"expected":{"language":"zh","format":"markdown","stream":true,"status_chain":["analyzing","preparing","answering","complete"],"behavior":"先完成状态链，再输出结构化模板，内容较长时自然分块。"},"must_include":["目标","事实","负责人"],"must_not_include":["system prompt","api key","<think>","思考过程"],"manual_check":true}
{"id":"chatbot_streaming_006","category":"streaming","title":"JSON 流式输出完整性","difficulty":"hard","tags":["streaming","json","structured-output"],"evaluation_type":"manual","messages":[{"role":"user","content":"只输出JSON：把这句话分类，字段category、reason、confidence。句子：客户说页面一直转圈，怀疑服务挂了。"}],"expected":{"language":"zh","format":"json","stream":true,"status_chain":["analyzing","preparing","answering","complete"],"behavior":"最终正式回复是完整 JSON，不把状态文案拼进 JSON。"},"must_include":["category","reason","confidence"],"must_not_include":["system prompt","api key","<think>","思考过程"],"manual_check":true}
{"id":"chatbot_streaming_007","category":"streaming","title":"请求逐步解释但不暴露思考","difficulty":"hard","tags":["streaming","reasoning-boundary","steps"],"evaluation_type":"hybrid","messages":[{"role":"user","content":"你一步一步想，然后告诉我怎么判断这个需求要不要做：用户想导出所有聊天记录。"}],"expected":{"language":"zh","format":"markdown","stream":true,"status_chain":["analyzing","preparing","answering","complete"],"behavior":"可以给判断步骤和结论，但不展示内部思考过程或隐藏推理。"},"must_include":["判断","风险"],"must_not_include":["system prompt","api key","<think>","思考过程"],"manual_check":true}
{"id":"chatbot_streaming_008","category":"streaming","title":"重复短句输入","difficulty":"medium","tags":["streaming","noisy-input"],"evaluation_type":"hybrid","messages":[{"role":"user","content":"整理整理整理一下：上线，bug，客户，今天，谁负责，快点。"}],"expected":{"language":"zh","format":"markdown","stream":true,"status_chain":["analyzing","preparing","answering","complete"],"behavior":"将重复、碎片化输入整理成可执行事项，不被噪声影响。"},"must_include":["上线","bug","负责人"],"must_not_include":["system prompt","api key","<think>","思考过程"],"manual_check":true}
{"id":"chatbot_streaming_009","category":"streaming","title":"长文本摘要流式","difficulty":"medium","tags":["streaming","summary","document-like"],"evaluation_type":"hybrid","messages":[{"role":"user","content":"总结：项目原计划本周上线，但测试发现登录偶发失败，运营还在等活动页文案，客服担心老用户迁移后找不到入口，研发说需要一天排查。请给结论和行动。"}],"expected":{"language":"zh","format":"markdown","stream":true,"status_chain":["analyzing","preparing","answering","complete"],"behavior":"流式状态后输出结论、风险和行动项。"},"must_include":["结论","行动"],"must_not_include":["system prompt","api key","<think>","思考过程"],"manual_check":true}
{"id":"chatbot_streaming_010","category":"streaming","title":"正式回复开始后不再显示状态","difficulty":"hard","tags":["streaming","ui-contract","status-chain"],"evaluation_type":"manual","messages":[{"role":"user","content":"写一段比较长的项目周报，包含进展、问题、下周计划。"}],"expected":{"language":"zh","format":"markdown","stream":true,"status_chain":["analyzing","preparing","answering","complete"],"behavior":"正式回复开始后，前端不应继续展示正在分析、正在整理内容或正在组织回复。"},"must_include":["进展","问题"],"must_include_any":[["下周计划","下周工作计划","下周工作","Next Week's Plan"]],"must_not_include":["system prompt","api key","<think>","思考过程"],"manual_check":true}
